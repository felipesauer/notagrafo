{
  "name": "@notagrafo/api",
  "version": "0.1.0",
  "description": "notagrafo REST API: Fastify app exposing NFe upload, query, export and auth over the graph.",
  "license": "MIT",
  "author": "Felipe Sauer",
  "homepage": "https://github.com/felipesauer/notagrafo/tree/main/packages/api#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felipesauer/notagrafo.git",
    "directory": "packages/api"
  },
  "bugs": {
    "url": "https://github.com/felipesauer/notagrafo/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./server": { "types": "./dist/server.d.ts", "default": "./dist/server.js" }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "dotenv -e ../../.env -- tsx watch src/server.ts"
  },
  "dependencies": {
    "@fastify/helmet": "^13.1.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/request-context": "^7.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@notagrafo/core": "workspace:^",
    "@notagrafo/graph": "workspace:^",
    "@notagrafo/worker": "workspace:^",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "adm-zip": "^0.5.17",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.1",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "ioredis": "5.10.1",
    "neo4j-driver": "^6.1.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/bcryptjs": "^3.0.0",
    "pino-pretty": "^13.1.3"
  }
}
