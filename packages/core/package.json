{
  "name": "@notagrafo/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run copy:schemas",
    "copy:schemas": "node -e \"require('node:fs').cpSync('src/schemas','dist/schemas',{recursive:true})\"",
    "dev": "tsc -p tsconfig.json --watch"
  }
}
