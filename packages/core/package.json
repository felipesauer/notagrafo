{
  "name": "@notagrafo/core",
  "version": "0.2.0",
  "description": "Core domain for notagrafo: NFe v4.00 types, parser, XSD validator and fiscal catalogs (NCM/CFOP).",
  "license": "MIT",
  "author": "Felipe Sauer",
  "homepage": "https://github.com/felipesauer/notagrafo/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felipesauer/notagrafo.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/felipesauer/notagrafo/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./lgpd": {
      "types": "./dist/utils/lgpd.utils.d.ts",
      "default": "./dist/utils/lgpd.utils.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && pnpm run copy:schemas",
    "copy:schemas": "node -e \"require('node:fs').cpSync('src/schemas','dist/schemas',{recursive:true})\"",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "fast-xml-parser": "^5.9.3",
    "libxmljs2": "^0.37.0"
  }
}
