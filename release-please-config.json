{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "separate-pull-requests": true,
  "include-component-in-tag": true,
  "plugins": ["node-workspace"],
  "packages": {
    "packages/core": {
      "component": "core"
    },
    "packages/graph": {
      "component": "graph"
    },
    "packages/worker": {
      "component": "worker"
    },
    "packages/api": {
      "component": "api"
    }
  }
}
