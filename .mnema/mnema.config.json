{
  "version": "1.0",
  "mnema_version": "^0.13.0-alpha.0",
  "project": {
    "key": "NOTA",
    "name": "notagrafo"
  },
  "paths": {
    "state": ".mnema/state",
    "audit": ".mnema/audit",
    "backlog": ".mnema/backlog",
    "sprints": ".mnema/sprints",
    "roadmap": ".mnema/roadmap",
    "memory": ".mnema/memory",
    "observations": ".mnema/observations",
    "skills": ".mnema/skills",
    "commands": ".mnema/commands",
    "templates": ".mnema/templates",
    "workflows": ".mnema/workflows"
  },
  "workflow": "default",
  "mode": "single",
  "audit_strategy": "recent",
  "audit_retention_months": 12,
  "audit": {
    "checkpoint": {
      "events": 100,
      "seconds": 3600
    },
    "anchor": {
      "provider": "none",
      "interval": {}
    }
  },
  "enforcement_mode": "advisory",
  "enforcement_field_severity": {},
  "sync": {
    "mode": "hybrid",
    "agent_buffer_flush_seconds": 30,
    "agent_buffer_flush_count": 50,
    "agent_buffer_flush_on_plan_complete": true
  },
  "features": {
    "fts_search": true,
    "attachments": true,
    "knowledge": true,
    "update_check": false
  },
  "aging": {
    "stale_after_days": 3,
    "orphan_run_after_hours": 24,
    "sla_days": {},
    "wip_limits": {}
  },
  "claims": {
    "lease_minutes": 30,
    "require_to_start": false
  },
  "github": {
    "done_pr_policy": "off"
  },
  "git": {
    "watch": false
  },
  "hooks": {
    "on_task_done": [],
    "on_task_transitioned": [],
    "on_decision_accepted": [],
    "on_sprint_closed": [],
    "on_sprint_canceled": [],
    "on_epic_closed": []
  }
}
