# notagrafo — variáveis de ambiente (referência completa)
#
# Copie este arquivo para .env e ajuste os valores.
# NUNCA commite o .env real — ele está no .gitignore.

# ── Modo demo ──────────────────────────────────────────────────
DEMO=false                        # true → seed com NFes fictícias no boot
DEMO_NF_COUNT=500                 # quantidade de NFes a gerar no seed
DEMO_AUTH_ENABLED=true            # em modo demo (DEMO=true) liga/desliga a auth; SOBREPÕE AUTH_ENABLED

# ── Neo4j ──────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687   # URI Bolt do Neo4j
NEO4J_USER=neo4j                  # usuário do Neo4j
NEO4J_PASSWORD=changeme           # senha do Neo4j (trocar em produção)

# ── Redis / BullMQ ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379  # conexão Redis usada pela fila BullMQ
WORKER_CONCURRENCY=4              # workers paralelos por instância
JOB_MAX_RETRIES=3                 # tentativas antes de ir para DLQ
JOB_BACKOFF_DELAY=5000            # delay inicial de retry em ms

# ── Storage de XMLs ────────────────────────────────────────────
XML_STORAGE_DRIVER=minio          # local | s3 | minio
XML_STORAGE_LOCAL_PATH=./data/xml # caminho local quando driver=local
XML_STORAGE_S3_BUCKET=notagrafo   # bucket S3 quando driver=s3
XML_STORAGE_S3_REGION=us-east-1   # região S3
XML_STORAGE_S3_ACCESS_KEY=        # access key S3 (vazio → usa credenciais do ambiente)
XML_STORAGE_S3_SECRET_KEY=        # secret key S3
XML_STORAGE_MINIO_ENDPOINT=http://localhost:9000  # endpoint MinIO quando driver=minio
XML_STORAGE_MINIO_ACCESS_KEY=minioadmin           # access key MinIO
XML_STORAGE_MINIO_SECRET_KEY=minioadmin           # secret key MinIO

# ── API ────────────────────────────────────────────────────────
PORT=3000                         # porta HTTP da API
NODE_ENV=development              # development | production
RATE_LIMIT_MAX=100                # requisições por janela
RATE_LIMIT_WINDOW=60000           # janela em ms

# ── Auth (JWT manual — ADR NOTA-ADR-1) ─────────────────────────
# Autenticação por JWT Bearer via @fastify/jwt (não Better Auth).
AUTH_ENABLED=true                 # false → desliga a auth (API + dashboard); DEMO_AUTH_ENABLED sobrepõe em modo demo
AUTH_SECRET=change-this-secret-in-production  # segredo de assinatura do JWT (trocar em produção)
AUTH_JWT_EXPIRES_IN=7d            # validade do token (ex.: 7d, 12h)

# ── Dashboard (Vite — build-time) ──────────────────────────────
# O dashboard é SPA: as flags de auth precisam estar disponíveis no build.
# Espelhe aqui as flags do backend (mesma semântica de sobreposição).
VITE_DEMO=false                   # espelha DEMO para o frontend
VITE_AUTH_ENABLED=true            # espelha AUTH_ENABLED
VITE_DEMO_AUTH_ENABLED=true       # espelha DEMO_AUTH_ENABLED (sobrepõe em modo demo)

# ── E-mail / magic-link (FUTURO — fora do MVP, ver ADR NOTA-ADR-1) ──
# SMTP e magic-link não fazem parte do MVP. Mailpit captura e-mails em dev.
# Descomente quando o envio de e-mail for implementado.
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_FROM=noreply@notagrafo.local

# ── Exportação ─────────────────────────────────────────────────
EXPORT_TTL_HOURS=24               # tempo de vida dos arquivos de exportação

# ── LGPD ───────────────────────────────────────────────────────
LGPD_MASK_CPF=false               # true → pseudonimiza CPFs de MEI nos logs e UI

# ── Observabilidade ────────────────────────────────────────────
OTEL_EXPORTER=console             # console | otlp | none
OTEL_ENDPOINT=http://localhost:4317  # endpoint OTLP quando OTEL_EXPORTER=otlp
